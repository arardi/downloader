<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/format_card_height"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_elevated_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/qualityBadge"
        android:layout_width="@dimen/quality_badge_width"
        android:layout_height="@dimen/quality_badge_height"
        android:background="@drawable/bg_quality_badge"
        android:ellipsize="end"
        android:gravity="center"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/formatLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/formatMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/taskBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_success_badge"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Prepared by API"
            android:textColor="@color/success"
            android:textSize="10sp" />
    </LinearLayout>

    <Button
        android:id="@+id/downloadButton"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:background="@drawable/bg_primary_button"
        android:drawableStart="@drawable/ic_download"
        android:drawablePadding="6dp"
        android:minWidth="104dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="Download"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
