<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/screenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/downloadBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/download_panel_margin"
        android:layout_marginEnd="@dimen/download_panel_margin"
        android:layout_marginBottom="@dimen/nav_safe_bottom_extra"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="18dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/downloadPanelHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/downloadPanelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="Preparing..."
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/downloadPanelPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="0%"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/downloadPanelToggle"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@color/transparent"
                android:contentDescription="Collapse download panel"
                android:padding="8dp"
                android:src="@drawable/ic_chevron_down" />

            <ImageButton
                android:id="@+id/downloadPanelClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/close"
                android:padding="10dp"
                android:src="@drawable/ic_close"
                android:tint="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/downloadSizeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Preparing selected quality"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/downloadProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress" />

        <LinearLayout
            android:id="@+id/downloadPanelContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/downloadStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Preparing selected quality"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/downloadFileText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="Download"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/retryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_secondary_button"
                    android:drawableStart="@drawable/ic_retry"
                    android:drawablePadding="6dp"
                    android:minWidth="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Retry"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/openFileButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_secondary_button"
                    android:drawableStart="@drawable/ic_open"
                    android:drawablePadding="6dp"
                    android:minWidth="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Open file"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
